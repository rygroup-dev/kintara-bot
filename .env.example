# ============================================================
#  KINTARA BOT — .env configuration
#  Fill only the 2 REQUIRED fields below. Everything else is optional.
#  NEVER commit the real .env file — it is already git-ignored.
# ============================================================

# ===== REQUIRED =====
# 1) Solana wallet private key (base58). The bot uses it to log in
#    automatically by signing the challenge. No manual cookie/session required.
WALLET_PRIVATE_KEY=

# 2) Telegram bot token from @BotFather (format: 1234567890:AAxxxxxxxx)
TELEGRAM_BOT_TOKEN=

# ===== OPTIONAL =====
# Your Telegram chat ID. Leave empty to auto-capture it when you send /start.
TELEGRAM_CHAT_ID=

# Game shard/server (default: s2). Change it if you want another server (s1..s12).
KINTARA_SHARD=s2

# API hosts. Defaults are usually correct and rarely need changes.
KINTARA_API_BASE=https://kintara.gg
KINTARA_FANOUT_BASE=https://ktra-server-b.onrender.com


# Combat supplies
COMBAT_MIN_GOLD=20
COMBAT_MIN_HEALTH_POTIONS=6
COMBAT_MIN_SHIELD_POTIONS=2